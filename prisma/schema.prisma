generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AnimeManga {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String
  type        Type
  status      StatusType
  isFavorite  Boolean  @default(false)
  genre       String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Type {
  Anime
  Manga
}

enum StatusType {
  Watching
  Reading
  Completed
  PlanToWatch
  PlanToRead
}