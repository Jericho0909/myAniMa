generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AnimeManga {
  id          String   @id @default(cuid())
  title       String
  description String
  image       String
  type        String
  status      StatusType
  isFavorite  Boolean  @default(false)
  genre       String[]
}

enum StatusType {
  Watching
  Reading
  Completed
  PlanToWatch
  PlanToRead
}